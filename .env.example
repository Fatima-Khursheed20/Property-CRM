# Copy to `.env.local` for local development

MONGODB_URI=mongodb://localhost:27017/property_crm

JWT_SECRET=change-this-secret-min-16-characters-long

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional extra inbox for new-lead alerts (comma-separated)
# ADMIN_NOTIFY_EMAIL=

# SMTP — omit to log emails to console in development
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=

# Seed (`npm run seed`) — optional overrides
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_NAME=Admin
